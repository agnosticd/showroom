{% set _provider = (showroom_tls_provider | default(certbot_cert_manager_provider, true) | default('zerossl')) | lower %}
{% set _entrypoint = 'web' if _provider == 'none' else 'websecure' %}
{% set _sidecar_base = showroom_nookbag_sidecar_base_url | default('', true) %}
{% if not _sidecar_base %}
{%   set _sidecar_base = 'http://reverse-proxy:80' if _provider == 'none' else 'https://reverse-proxy:443' %}
{% endif %}
nookbag-sidecar:
  image: {{ showroom_nookbag_sidecar_image }}:{{ showroom_nookbag_sidecar_image_tag }}
  container_name: nookbag-sidecar
  hostname: nookbag-sidecar
  restart: always
  environment:
    HEALTHZ_PORT: "{{ showroom_nookbag_sidecar_port }}"
    HEALTHZ_BASE_URL: "{{ _sidecar_base }}"
    HEALTHZ_HOST: "{{ showroom_host }}"
    NOOKBAG_BASE: "{{ showroom_nookbag_sidecar_nookbag_base }}"
  labels:
    - "traefik.enable=true"
    - "traefik.http.services.healthz.loadbalancer.server.port={{ showroom_nookbag_sidecar_port }}"
    - "traefik.http.routers.healthz.entrypoints={{ _entrypoint }}"
{% if _provider != 'none' %}
    - "traefik.http.routers.healthz.tls.certresolver={{ _provider }}"
{% endif %}
    - "traefik.http.routers.healthz.rule=Host(`{{ showroom_host }}`) && (Path(`/healthz`) || Path(`/readyz`))"
    - "traefik.http.routers.healthz.service=healthz"
    - "traefik.http.routers.healthz.priority=100"
