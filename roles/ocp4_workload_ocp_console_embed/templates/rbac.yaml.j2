# RBAC to let the webhook pod reconcile the oauth-openshift route
# directly via the Kubernetes API (startup + periodic check).
apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  name: "{{ ocp_console_embed_name }}-route-manager"
  namespace: openshift-authentication
rules:
  - apiGroups:
      - route.openshift.io
    resources:
      - routes
    resourceNames:
      - oauth-openshift
    verbs:
      - get
      - patch
  - apiGroups:
      - route.openshift.io
    resources:
      - routes
    verbs:
      - list
      - watch
  - apiGroups:
      - route.openshift.io
    resources:
      - routes/custom-host
    verbs:
      - create
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: "{{ ocp_console_embed_name }}-route-manager"
  namespace: openshift-authentication
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: Role
  name: "{{ ocp_console_embed_name }}-route-manager"
subjects:
  - kind: ServiceAccount
    name: "{{ ocp_console_embed_name }}"
    namespace: "{{ ocp_console_embed_namespace }}"
