---
# Automatically generated Showroom Compose Orchestration file
# via AgnosticD showroom role
# https://github.com/redhat-cop/agnosticd/tree/development/ansible/roles/showroom

version: "3"

services:

{% for service in showroom_base_services %}
{% macro fake_indent_op() %}
{% include 'base_service_' + service + '/base_service_' + service + '.j2' ignore missing %}
{% endmacro %}
  {{ fake_indent_op() | indent(2) }}

{% endfor %}

{% if showroom_nookbag_sidecar_enable | default(true) | bool %}
{% macro fake_indent_op() %}
{% include 'service_nookbag_sidecar/service_nookbag_sidecar.j2' ignore missing %}
{% endmacro %}
  {{ fake_indent_op() | indent(2) }}

{% endif %}

{% if showroom_runtime_automation_enable | default(false) | bool or showroom_ansible_runner_api | default(false) | bool %}
{% macro fake_indent_op() %}
{% include 'service_runtime_automation/service_runtime_automation.j2' ignore missing %}
{% endmacro %}
  {{ fake_indent_op() | indent(2) }}

{% endif %}

{% for service in showroom_tab_services %}
{% macro fake_indent_op() %}
{% include 'service_' + service + '/service_' + service + '.j2' ignore missing %}
{% endmacro %}
  {{ fake_indent_op() | indent(2) }}

{% endfor %}

networks:
  default:
    name: {{ showroom_podman_network | default('showroom_network') }}
    external: true
